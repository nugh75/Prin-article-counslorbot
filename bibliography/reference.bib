@article{neumann2021,
	title = {Chatbots as a Tool to Scale Mentoring Processes: Individually Supporting Self-Study in Higher Education},
	author = {Neumann, Alexander Tobias and Arndt, Tamar and K{\"o}bis, Laura and Meissner, Roy and Martin, Anne and de Lange, Peter and Pengel, Norbert and Klamma, Ralf and Wollersheim, Heinz-Werner},
	year = {2021},
	journal = {Frontiers in Artificial Intelligence},
	volume = {4},
	pages = {668220},
	doi = {10.3389/frai.2021.668220},
	abstract = {Like most curricula in the humanities and social sciences, the curriculum of pre-service teacher training in educational sciences often includes time-consuming reading and writing tasks, which require high quality support and feedback in a timely manner. A well-known way to provide this support is one-to-one mentoring. However, limited time and resources in the German university context require to effectively scale the benefits of individual feedback. The use of scalable technologies to support learning processes seems promising, but its development usually requires a deep technical understanding. With an interdisciplinary approach, this contribution investigates how personal mentoring can be made available to as many students as possible, taking into account the didactic, organizational and technical frameworks at universities. We describe the implementation process of two chatbots that both aim to support students in their self-study of seminar topics and literature. The chatbots were used by over 700 students during the course of 1 year and our evaluations show promising results that bear the potential to improve the availability of digital mentoring support for all students.}
}

@article{wollny2021,
	title = {Are We There Yet? -- A Systematic Literature Review on Chatbots in Education},
	author = {Wollny, Sebastian and Schneider, Jan and Di Mitri, Daniele and Weidlich, Joshua and Rittberger, Marc and Drachsler, Hendrik},
	year = {2021},
	journal = {Frontiers in Artificial Intelligence},
	volume = {4},
	pages = {654924},
	doi = {10.3389/frai.2021.654924},
	abstract = {Chatbots are a promising technology with the potential to enhance workplaces and everyday life. In terms of scalability and accessibility, they also offer unique possibilities as communication and information tools for digital learning. In this paper, we present a systematic literature review investigating the areas of education where chatbots have already been applied, the pedagogical roles of chatbots, the use of chatbots for mentoring purposes, and their potential to personalize education. We conducted a preliminary analysis of 2,678 publications to perform a literature review, which allowed us to identify 74 relevant publications on chatbots' application in education. Through this, we address five research questions that, together, allow us to explore the current state-of-the-art of this educational technology. We conclude our systematic literature review by pointing to three main research challenges: 1) Aligning chatbot evaluations with implementation objectives, 2) Exploring the potential of chatbots for mentoring students, and 3) Leveraging the adaptation capabilities of chatbots.}
}

@article{kuhail2022,
	title = {Interacting with Educational Chatbots: A Systematic Review},
	author = {Kuhail, Mohammad Amin and Alturki, Nazik and Alramlawi, Salwa and Alhejori, Kholood},
	year = {2022},
	journal = {Education and Information Technologies},
	volume = {28},
	number = {1},
	pages = {973--1018},
	doi = {10.1007/s10639-022-11177-3},
	abstract = {Chatbots hold the promise of revolutionizing education by engaging learners, personalizing learning activities, supporting educators, and developing deep insight into learners' behavior. However, there is a lack of studies that analyze the recent evidence-based chatbot-learner interaction design techniques applied in education. This study presents a systematic review of 36 papers to understand, compare, and reflect on recent attempts to utilize chatbots in education using seven dimensions: educational field, platform, design principles, the role of chatbots, interaction styles, evidence, and limitations. The results show that chatbots were mainly designed on a web platform to teach computer science, language, and general education. Furthermore, more than half of chatbots used as teaching agents, while more than a third acted as peer agents.}
}

@article{chang2023,
	title = {Educational Design Principles of Using AI Chatbot That Supports Self-Regulated Learning in Education: Goal Setting, Feedback, and Personalization},
	author = {Chang, Daniel H. and Lin, Michael Pin-Chuan and Hajian, Shiva and Wang, Quincy Q.},
	year = {2023},
	journal = {Sustainability},
	volume = {15},
	number = {17},
	pages = {12921},
	doi = {10.3390/su151712921},
	abstract = {The invention of ChatGPT and generative AI technologies presents educators with significant challenges. This paper proposes three key pedagogical principles for integrating AI chatbots in classrooms, informed by Zimmerman's Self-Regulated Learning (SRL) framework and Judgment of Learning (JOL). First, we propose that teaching prompting is important for developing students' SRL. Second, configuring reverse prompting the chatbot's AI capability will help guide students' SRL monitoring and understanding. Third, developing a data-driven mechanism that enables an AI chatbot to provide learning analytics that helps learners reflect on their learning and develop SRL strategies.}
}

@article{kasneci2023,
	title = {ChatGPT for Good? On Opportunities and Challenges of Large Language Models for Education},
	author = {Kasneci, Enkelejda and Se{\ss}ler, Kathrin and K{\"u}chemann, Stefan and Bannert, Maria and Dementieva, Daryna and Fischer, Frank and Gasser, Urs and Groh, Georg and G{\"u}nnemann, Stephan and H{\"u}llermeier, Eyke and Krusche, Stephan and Kutyniok, Gitta and Michaeli, Tilman and Nerdel, Claudia and Pfeffer, J{\"u}rgen and Poquet, Oleksandra and Sailer, Michael and Schmidt, Albrecht and Seidel, Tina and Stadler, Matthias and Weller, Jochen and Kuhn, Jochen and Kasneci, Gjergji},
	year = {2023},
	journal = {Learning and Individual Differences},
	volume = {103},
	pages = {102274},
	doi = {10.1016/j.lindif.2023.102274},
	abstract = {Large language models represent a significant advancement in the field of AI. This position paper presents the potential benefits and challenges of educational applications of large language models, from student and teacher perspectives. We highlight how these models can be used to create educational content, improve student engagement and interaction, and personalize learning experiences. Challenges include the potential bias in the output, the need for continuous human oversight, and the potential for misuse. We conclude with recommendations for how to address these challenges and ensure that such models are used in a responsible and ethical manner in education.}
}

@article{antunes2025,
	title = {Large Language Models as Socratic Mentors: Transforming Educational Approaches for Epistemic Development},
	author = {Antunes, Luiz G. and Passarelli, Brasilina and Claro, Sushila V.},
	year = {2025},
	journal = {Arac{\^e}},
	volume = {7},
	number = {5},
	pages = {24921--24936},
	doi = {10.56238/arev7n5-229},
	abstract = {This paper examines how Large Language Models (LLMs) can transform educational approaches by functioning as Socratic mentors rather than mere information providers. Drawing on dialogic pedagogy and constructivist learning theories, we propose a framework positioning LLMs as epistemological catalysts that emphasize epistemic agency, perspective multiplicity, and metacognitive development.}
}

@article{zawacki-richter2019,
	title = {Systematic Review of Research on Artificial Intelligence Applications in Higher Education -- Where Are the Educators?},
	author = {Zawacki-Richter, Olaf and Mar{\'i}n, Victoria I. and Bond, Melissa and Gouverneur, Franziska},
	year = {2019},
	journal = {International Journal of Educational Technology in Higher Education},
	volume = {16},
	number = {1},
	pages = {39},
	doi = {10.1186/s41239-019-0171-0},
	abstract = {This paper provides an overview of research on AI applications in higher education through a systematic review. Out of 2656 initially identified publications for the period between 2007 and 2018, 146 articles were included. The synthesis presents four areas of AIEd applications: profiling and prediction, assessment and evaluation, adaptive systems and personalisation, and intelligent tutoring systems. The conclusions reflect on the almost total lack of critical reflection of the challenges and risks of AIEd.}
}

@article{mendez2020,
	title = {Chatbots: A Tool to Supplement the Future Faculty Mentoring of Doctoral Engineering Students},
	author = {Mendez, Sylvia and Johanson, Katie and Conley, Valerie Martin and Gosha, Kinnis and Mack, Naja A. and Haynes, Comas and Gerhardt, Rosario A.},
	year = {2020},
	journal = {International Journal of Doctoral Studies},
	volume = {15},
	pages = {373--392},
	doi = {10.28945/4579},
	abstract = {This study explores the efficacy of simulated interactive virtual conversations (chatbots) for mentoring underrepresented minority doctoral engineering students considering a career in the professoriate or industry. Findings indicate that while students have ample unmet mentoring needs, they are overall satisfied with the user interface and trustworthiness of the chatbots, but their intent to use them is mixed due to a lack of personalization in the type of mentoring relationship.}
}

@article{su2020,
	title = {Development of an AI Chatbot to Support Admissions and Career Guidance for Universities},
	author = {Su, Le Hoanh and Truong, Dang-Huy and Tran, Thi-Yen-Linh and Nguyen, Thi-Duyen-Ngoc and Ly, Bao-Tuyen and Nguyen, Ha-Phuong-Truc},
	year = {2020},
	journal = {IJEMR},
	volume = {4},
	number = {2},
	pages = {13--20},
	doi = {10.22662/IJEMR.2020.4.2.013},
	abstract = {This paper explores building an AI chatbot to support admissions and career guidance for universities. A chatbot can be available 24/7 and processes requests of students/parents automatically and quickly, especially optimized in repetitive scenarios. The thesis builds a structured dataset about enrollment orientation and applies natural language processing and machine learning to build identification models.}
}

@incollection{dsilva2020,
	title = {Career Counselling Chatbot Using Cognitive Science and Artificial Intelligence},
	author = {D'silva, Godson Michael and Jani, Megh and Jadhav, Vipul and Bhoir, Amit and Amin, Prithvi N.},
	year = {2020},
	booktitle = {Advanced Computing Technologies and Applications},
	editor = {Vasudevan, Hemant and Michalas, Antonios and Shekokar, Narendra and Narvekar, M.},
	series = {Algorithms for Intelligent Systems},
	publisher = {Springer},
	pages = {1--9},
	doi = {10.1007/978-981-15-3242-9_1},
	abstract = {This paper proposes a career counselling chatbot that combines cognitive science and artificial intelligence to provide personalized career guidance to students. The system uses a rule-based approach integrated with machine learning to analyze user profiles and suggest suitable career paths.}
}

@misc{chu2024,
	title = {Assessing Vocational Interests through Chat: Development and Validation of the Career Guidance Chatbot (CGC-bot)},
	author = {Chu, Chu and Sun, Tianjun and Zhang, Bo and Rounds, James},
	year = {2024},
	doi = {10.31234/osf.io/upx5q},
	abstract = {The current research developed the Career Guidance Chatbot (CGC-bot) that collects high-quality, diverse work preference information from users, and subsequent NLP + ML algorithm-powered machines that predict basic interest scores from user's chat with the CGC-bot, and searches for top O*NET occupations based on user's basic interest profile prediction. 1250 U.S. adults and 328 college students completed a two-part study: one part chatting with the CGC-bot, the other completing a basic interest survey. Results suggested that machine-predicted scores shared comparable psychometric properties as self-reported scores, though participants enjoyed the chatbot less due to higher mental demand and longer interaction time.}
}

@article{leung2022,
	title = {New Frontiers in Computer-Assisted Career Guidance Systems (CACGS): Implications From Career Construction Theory},
	author = {Leung, S. Alvin},
	year = {2022},
	journal = {Frontiers in Psychology},
	volume = {13},
	pages = {786232},
	doi = {10.3389/fpsyg.2022.786232},
	note = {PDF: bibliography/pdf/2022_leung_new-frontiers-in-computer-assisted-career-guidance-systems.pdf},
	abstract = {This article addresses the use of CACGS in career interventions. Major CACGS developed in past decades were based on trait-factor or person-environment fit approaches. Career Construction Theory (CCT) is proposed as a promising paradigm to guide new generations of CACGS. A digital system called Infinity (Hong Kong) is presented, offering quantitative/qualitative assessments, gamified tools, and social support. Initial findings showed users reported lesser decision-making difficulties, higher decision clarity, and better understanding of career planning than non-users.}
}

@article{wang2024,
	title = {Career construction theory: tools, interventions, and future trends},
	author = {Wang, Danqi and Li, Yanling},
	year = {2024},
	journal = {Frontiers in Psychology},
	volume = {15},
	pages = {1381233},
	doi = {10.3389/fpsyg.2024.1381233},
	note = {PDF: bibliography/pdf/2024_wang-li_career-construction-theory-tools-interventions-and-future-trends.pdf},
	abstract = {This mini-review introduces and analyzes qualitative assessment tools of career construct theory, including the Career Construction Interview and "My Career Story" workbook, and intervention approaches including CACGS, workshops, group counseling, and individual counseling. Future research directions include analysis of effective interventions for specific groups, career intervention in the digital age, and standardization of assessment tools.}
}

@article{liu2025,
	title = {Assessing strategic use of artificial intelligence in self-regulated learning: Instrument development and evidence from Chinese university students},
	author = {Liu, Xiao-hua and Xiao, Yangyu and Li, Danling},
	year = {2025},
	journal = {International Journal of Educational Technology in Higher Education},
	volume = {22},
	doi = {10.1186/s41239-025-00567-5},
	note = {PDF: bibliography/pdf/2025_liu-et-al_assessing-strategic-use-of-ai-in-self-regulated-learning.pdf},
	abstract = {This study develops and validates a strategy inventory for assessing strategic AI use in self-regulated learning. Factor and Rasch analyses identified eight factors: four pertaining to regulation of AI-assisted task processing, and four associated with regulation of AI application. Results showed output-focused metacognitive regulation was most frequent, while AI-supported self-assessment strategies were underutilized. The instrument can be used by teachers to diagnose strategy use and by students for self-assessment.}
}

@article{amershi2014,
	title = {Power to the People: The Role of Humans in Interactive Machine Learning},
	author = {Amershi, Saleema and Cakmak, Maya and Knox, W. Bradley and Kulesza, Todd},
	year = {2014},
	journal = {AI Magazine},
	volume = {35},
	number = {4},
	pages = {105--120},
	doi = {10.1609/aimag.v35i4.2513},
	note = {PDF: bibliography/pdf/2014_amershi-et-al_power-to-the-people-the-role-of-humans-in-interactive-machine-learning.pdf},
	abstract = {This paper characterizes the role of humans in interactive machine learning (IML). The authors argue that IML systems must treat users as first-order learners and designers, actively involving them in the model-building process. They identify key challenges and design principles for effective human interaction with machine learning systems, including providing users with appropriate mental models, enabling iterative and incremental model refinement, and supporting users in understanding and correcting model behavior. A foundational paper on human-AI interaction and the importance of human-centered ML.},
}

% --- Riferimenti citati in Giannakos et al. 2024 (promise_challenges_genai), PDF open access in bibliography/pdf/ ---

@inproceedings{tankelevitch2024,
	title = {The Metacognitive Demands and Opportunities of Generative AI},
	author = {Tankelevitch, Lev and Kewenig, Viktor and Simkute, Auste and Scott, Ava Elizabeth and Sarkar, Advait and Sellen, Abigail and Rintel, Sean},
	year = {2024},
	booktitle = {Proceedings of the 2024 CHI Conference on Human Factors in Computing Systems (CHI '24)},
	pages = {1--24},
	doi = {10.1145/3613904.3642902},
	note = {PDF: bibliography/pdf/2024_tankelevitch-et-al_the-metacognitive-demands-and-opportunities-of-generative-ai.pdf (arXiv:2312.10893)},
	abstract = {Generative AI (GenAI) systems offer unprecedented opportunities for transforming professional and personal work, yet present challenges around prompting, evaluating and relying on outputs, and workflow management. The authors argue that metacognition---the psychological ability to monitor and control one's thoughts and behaviour---offers a useful lens to understand and design for these usability challenges. Effective GenAI use requires a high degree of metacognitive monitoring and control: forming prompts demands self-awareness of task goals (metacognitive knowledge), and evaluating outputs requires well-calibrated confidence. The paper derives design implications for supporting users' metacognition and for reducing the metacognitive demand of GenAI systems.}
}

@article{cukurova2020,
	title = {Impact of an Artificial Intelligence Research Frame on the Perceived Credibility of Educational Research Evidence},
	author = {Cukurova, Mutlu and Luckin, Rose and Kent, Carmel},
	year = {2020},
	journal = {International Journal of Artificial Intelligence in Education},
	volume = {30},
	number = {2},
	pages = {205--235},
	doi = {10.1007/s40593-019-00188-w},
	note = {PDF: bibliography/pdf/2020_cukurova-et-al_impact-of-an-artificial-intelligence-research-frame.pdf},
	abstract = {Using a randomized experiment, this study investigates whether framing identical educational research evidence as coming from Artificial Intelligence rather than from educational psychology or neuroscience affects how credible practitioners judge it to be. Participants tended to rate the same content as less credible when it was attributed to AI, revealing a mistrust of AI-framed evidence. The findings have direct implications for how AI-generated content and recommendations should be presented to teachers and learners to support---rather than undermine---trust and uptake.}
}

@inproceedings{bender2021,
	title = {On the Dangers of Stochastic Parrots: Can Language Models Be Too Big?},
	author = {Bender, Emily M. and Gebru, Timnit and McMillan-Major, Angelina and Shmitchell, Shmargaret},
	year = {2021},
	booktitle = {Proceedings of the 2021 ACM Conference on Fairness, Accountability, and Transparency (FAccT '21)},
	pages = {610--623},
	doi = {10.1145/3442188.3445922},
	note = {PDF: bibliography/pdf/2021_bender-et-al_on-the-dangers-of-stochastic-parrots.pdf},
	abstract = {This foundational critique argues that ever-larger language models trained on uncurated web text carry environmental and financial costs, encode and amplify social bias, and produce fluent text without any grounding in meaning or communicative intent---hence ``stochastic parrots.'' Because such models recombine training data according to probabilistic information about how forms combine, without reference to meaning, their coherence is in the eye of the beholder. The paper recommends careful curation, documentation, and value-sensitive design. Source of the ``stochastic parrots'' framing used in Giannakos et al. (2024) to characterise the limits of LLMs in education.}
}

@article{akata2020,
	title = {A Research Agenda for Hybrid Intelligence: Augmenting Human Intellect With Collaborative, Adaptive, Responsible, and Explainable Artificial Intelligence},
	author = {Akata, Zeynep and Balliet, Dan and de Rijke, Maarten and Dignum, Frank and Dignum, Virginia and Eiben, Guszti and Fokkens, Antske and Grossi, Davide and Hindriks, Koen and Hoos, Holger and Hung, Hayley and Jonker, Catholijn and Monz, Christof and Neerincx, Mark and Oliehoek, Frans and Prakken, Henry and Schlobach, Stefan and van der Gaag, Linda and van Harmelen, Frank and van Hoof, Herke and van Riemsdijk, Birna and van Wynsberghe, Aimee and Verbrugge, Rineke and Verheij, Bart and Vossen, Piek and Welling, Max},
	year = {2020},
	journal = {Computer},
	volume = {53},
	number = {8},
	pages = {18--28},
	doi = {10.1109/MC.2020.2996587},
	note = {PDF: bibliography/pdf/2020_akata-et-al_a-research-agenda-for-hybrid-intelligence.pdf},
	abstract = {This agenda-setting paper defines Hybrid Intelligence (HI) as the combination of human and machine intelligence to augment---rather than replace---human intellect, leveraging the complementary strengths of each. The authors identify four central research challenges for systems that collaborate with, adapt to, are accountable to, and are explainable to humans: collaborative, adaptive, responsible, and explainable AI. Reference pillar for the ``augment, not replace'' and human-AI complementarity argument recurring across Giannakos et al. (2024).}
}

@article{susnjak2023,
	title = {Beyond Predictive Learning Analytics Modelling and Onto Explainable Artificial Intelligence With Prescriptive Analytics and ChatGPT},
	author = {Susnjak, Teo},
	year = {2023},
	journal = {International Journal of Artificial Intelligence in Education},
	volume = {34},
	pages = {1--31},
	doi = {10.1007/s40593-023-00336-3},
	note = {PDF: bibliography/pdf/2023_susnjak_beyond-predictive-learning-analytics-modelling.pdf},
	abstract = {This study proposes a framework that moves learning analytics from predictive modelling to explainable AI (XAI) and prescriptive analytics, using counterfactual explanations and a ChatGPT-based conversational layer to translate model outputs into human-readable, actionable feedback for at-risk students. It demonstrates how generative conversational AI can make analytics interpretable and support reflection and intervention, relevant to feedback generation and learner-facing dashboards.}
}

@misc{chen2021,
	title = {Evaluating Large Language Models Trained on Code},
	author = {Chen, Mark and Tworek, Jerry and Jun, Heewoo and Yuan, Qiming and Pinto, Henrique Ponde de Oliveira and Kaplan, Jared and Edwards, Harri and Burda, Yuri and Joseph, Nicholas and Brockman, Greg and others},
	year = {2021},
	howpublished = {arXiv:2107.03374},
	doi = {10.48550/arXiv.2107.03374},
	note = {PDF: bibliography/pdf/2021_chen-et-al_evaluating-large-language-models-trained-on-code.pdf},
	abstract = {Introduces Codex, a GPT language model fine-tuned on publicly available code from GitHub, which powered GitHub Copilot. The paper evaluates its Python code-writing capabilities on the HumanEval benchmark and discusses the broader impacts of code-generation models. Cited in Giannakos et al. (2024) as the milestone underpinning the LLM revolution in computer-science education and the 2021--2023 history of conversational/code-generation systems.}
}

@article{decarolis2006,
	title = {Supporting Students with a Personal Advisor},
	author = {De Carolis, Berardina and Pizzutilo, Sebastiano and Cozzolongo, Giovanni and Drozda, Paweł and Muci, Francesca},
	year = {2006},
	journal = {Educational Technology \& Society},
	volume = {9},
	number = {4},
	pages = {27--41},
	note = {PDF: bibliography/pdf/2006_decarolis-et-al_supporting-students-with-a-personal-advisor.pdf},
	abstract = {This paper presents a general architecture of an Embodied Conversational Agent (ECA) whose aim is to assist university students by providing personalized suggestions. The ECA acts as the student interface to a Virtual University environment offering different services and, to support mobility, is designed to run also on the student's handheld device. The authors discuss the design and technical issues of building this personal agent and report an evaluation study assessing the impact of conversational agents on the effectiveness of interaction. An early (pre-LLM) example of a pedagogical/orientation conversational agent acting as a personal advisor for students, relevant as a historical precedent for counseling/advising chatbots.}
}

@article{lee2017,
	title = {Enhancing User Experience with Conversational Agent for Movie Recommendation: Effects of Self-Disclosure and Reciprocity},
	author = {Lee, SeoYoung and Choi, Junho},
	year = {2017},
	journal = {International Journal of Human-Computer Studies},
	volume = {103},
	pages = {95--105},
	doi = {10.1016/j.ijhcs.2017.02.005},
	note = {PDF: non disponibile (paywall Elsevier/ScienceDirect; da reperire via accesso istituzionale)},
	abstract = {This study investigates how communication strategies of a conversational agent---self-disclosure and reciprocity---shape the user experience of an interactive movie-recommendation system. Through an experiment, the authors examine how these communication variables affect the human--agent relationship (intimacy, trust, and interactional enjoyment) and, in turn, user satisfaction and intention to use the system. Results show that an agent's self-disclosure and reciprocal exchange enhance the perceived relationship and overall user experience. Relevant as empirical evidence that social/relational conversational design (self-disclosure, reciprocity) improves engagement and trust in recommender chatbots---a precedent for relational design in counseling/advising agents.}
}

@article{noy2023,
	title = {Experimental Evidence on the Productivity Effects of Generative Artificial Intelligence},
	author = {Noy, Shakked and Zhang, Whitney},
	year = {2023},
	journal = {Science},
	volume = {381},
	number = {6654},
	pages = {187--192},
	doi = {10.1126/science.adh2586},
	note = {PDF: bibliography/pdf/2023_noy-zhang_experimental-evidence-on-the-productivity-effects-of-generative-ai.pdf},
	abstract = {We examined the productivity effects of a generative AI technology (ChatGPT) through a preregistered online experiment with 453 college-educated professionals. ChatGPT substantially raised productivity: average task time decreased by 40\% and output quality rose by 18\%. Inequality between workers decreased, and concern and excitement about AI temporarily rose.}
}

@article{yan2024,
	title = {Promises and Challenges of Generative Artificial Intelligence for Human Learning},
	author = {Yan, Lixiang and Greiff, Samuel and Teuber, Ziwen and Gašević, Dragan},
	year = {2024},
	journal = {Nature Human Behaviour},
	volume = {8},
	number = {10},
	pages = {1839--1850},
	doi = {10.1038/s41562-024-02004-5},
	note = {PDF: bibliography/pdf/2024_yan-et-al_promises-and-challenges-of-generative-ai-for-human-learning.pdf},
	abstract = {This review synthesizes evidence on how generative AI affects learning processes, self-regulated learning, metacognition, and assessment. It discusses both the potential benefits of AI for personalized learning and the risks of over-reliance, emphasizing the need for pedagogical frameworks that preserve learner agency.}
}

@article{fan2024,
	title = {Beware of Metacognitive Laziness: Effects of Generative Artificial Intelligence on Learning Motivation, Processes, and Performance},
	author = {Fan, Yizhou and Tang, Luzhen and Le, Huixiao and Shen, Kejie and Tan, Shufang and Zhao, Yueying and Shen, Yuan and Li, Xinyu and Gašević, Dragan},
	year = {2024},
	journal = {British Journal of Educational Technology},
	volume = {56},
	number = {2},
	pages = {489--530},
	doi = {10.1111/bjet.13544},
	note = {PDF: bibliography/pdf/2024_fan-et-al_beware-of-metacognitive-laziness.pdf},
	abstract = {Randomised experimental study comparing learners working with ChatGPT, AI expert, writing analytics tools, or no extra tool. Results showed that while the ChatGPT group outperformed in essay scores, they exhibited no significant differences in intrinsic motivation, self-regulated learning processes, or knowledge transfer, suggesting a risk of "metacognitive laziness" induced by AI reliance.}
}

@article{darvishi2024,
	title = {Impact of AI Assistance on Student Agency},
	author = {Darvishi, Ali and Khosravi, Hassan and Sadiq, Shazia and Gašević, Dragan and Siemens, George},
	year = {2024},
	journal = {Computers \& Education},
	volume = {210},
	pages = {104967},
	doi = {10.1016/j.compedu.2023.104967},
	note = {PDF: bibliography/pdf/2024_darvishi-et-al_impact-of-ai-assistance-on-student-agency.pdf},
	abstract = {RCT with 1625 students across 10 courses investigating whether AI assistance affects student agency and self-regulation. Results suggest that students tended to rely on AI rather than learning from it, and hybrid human-AI approaches did not complement AI assistance. Implications for designing AI that supports rather than undermines learner autonomy.}
}

@article{banihashem2024,
	title = {Feedback Sources in Essay Writing: Peer-Generated or AI-Generated Feedback?},
	author = {Banihashem, Seyyed Kazem and Taghizadeh Kerman, Nafiseh and Noroozi, Omid and Moon, Jewoong and Drachsler, Hendrik},
	year = {2024},
	journal = {International Journal of Educational Technology in Higher Education},
	volume = {21},
	number = {1},
	pages = {23},
	doi = {10.1186/s41239-024-00455-4},
	note = {PDF: bibliography/pdf/2024_banihashem-et-al_feedback-sources-in-essay-writing.pdf},
	abstract = {This study compared ChatGPT-generated feedback with peer feedback in essay writing (74 graduate students). ChatGPT provided more descriptive feedback and information about how essays were written, while peers focused on problem identification. No significant overall relationship was found between feedback source and essay quality, suggesting complementary roles for AI and peer feedback.}
}

@article{sharma2025,
	title = {The Role of Large Language Models in Personalized Learning: A Systematic Review of Educational Impact},
	author = {Sharma, Sahil and Mittal, Puneet and Kumar, Mukesh and Bhardwaj, Vivek},
	year = {2025},
	journal = {Discover Sustainability},
	volume = {6},
	number = {1},
	doi = {10.1007/s43621-025-01094-z},
	note = {PDF: bibliography/pdf/2025_sharma-et-al_role-of-llms-in-personalized-learning.pdf},
	abstract = {Systematic review of 55 studies (2020--2024) examining LLM-based learning systems for personalized learning. Covers student engagement, emotional and social development, real-time progress monitoring, and challenges including ethical considerations, privacy, and accessibility. Findings underscore the potential of LLMs to revolutionize personalized education.}
}

@article{balter2012,
	title = {The Effect of Short Formative Diagnostic Web Quizzes with Minimal Feedback},
	author = {Bälter, Olle and Enström, Emma and Klingenberg, Bernhard},
	year = {2012},
	journal = {Computers \& Education},
	volume = {60},
	number = {1},
	pages = {234--242},
	doi = {10.1016/j.compedu.2012.08.014},
	note = {PDF: bibliography/pdf/2012_balter-et-al_effect-of-short-formative-diagnostic-web-quizzes.pdf},
	abstract = {This study investigates the effect of short formative diagnostic web quizzes with minimal feedback on exam performance in a university course. Results showed that students who used the quizzes performed significantly better on the exam, suggesting that even minimal feedback can be effective when embedded in a formative assessment structure.}
}

@article{balter2011,
	title = {Feedback in Web-Based Questionnaires as Incentive to Increase Compliance in Studies on Lifestyle Factors},
	author = {Bälter, Olle and Fondell, Elinor and Bälter, Katarina},
	year = {2011},
	journal = {Public Health Nutrition},
	volume = {15},
	number = {6},
	pages = {982--988},
	doi = {10.1017/s1368980011003041},
	note = {PDF: bibliography/pdf/2011_balter-et-al_feedback-in-web-questionnaires-as-incentive.pdf},
	abstract = {This study explored the use of interactive web-based questionnaires with personalized feedback as an incentive to increase compliance in epidemiological studies. Results showed that 88\% of participants actively chose to receive feedback, and those who did showed higher compliance rates, demonstrating that feedback can effectively increase user engagement with web-based tools.}
}

@article{jemstedt2024,
	title = {Less to Produce and Less to Consume: The Advantage of Pure Question-Based Learning},
	author = {Jemstedt, Andreas and Bälter, Olle and Gavel, Alvin and Glassey, Richard and Bosk, Daniel},
	year = {2024},
	journal = {Interactive Learning Environments},
	doi = {10.1080/10494820.2024.2362830},
	note = {PDF: bibliography/pdf/2024_jemstedt-balter_less-to-produce-less-to-consume-pure-question-based-learning.pdf},
	abstract = {This study investigates pure question-based learning (pQBL), an online course format consisting solely of multiple-choice questions and detailed formative feedback. Compared to question-based learning with ordinary texts, pQBL resulted in equally good or better learning outcomes, with participants completing the course slightly faster, suggesting that question-driven interaction can be more efficient than content-heavy formats.}
}

